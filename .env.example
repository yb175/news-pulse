# Database configuration (PostgreSQL)
# Prisma-compatible connection string for local development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/newspulse?schema=public"

# Backend service port
PORT=5000

# Frontend public API URL
NEXT_PUBLIC_API_URL="http://localhost:5000/api"

# Scraper execution settings
SCRAPER_PYTHON_PATH="python3"
SCRAPER_INTERVAL_MINUTES=60
